# Sentinel File System Watcher Configuration
# Copy this to .env and fill in your paths

# Required: Directory to monitor for new files
WATCH_DIRECTORY=/path/to/watch

# Required: Obsidian Vault Inbox path
VAULT_INBOX_PATH=/path/to/vault/Inbox

# Optional: Seconds a file must be stable before processing (default: 2)
STABILITY_SECONDS=2

# Optional: Allowed file extensions (comma-separated, default: .md,.txt,.pdf,.jpg,.jpeg,.png)
ALLOWED_EXTENSIONS=.md,.txt,.pdf,.jpg,.jpeg,.png

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR; default: INFO)
LOG_LEVEL=INFO

# Optional: Log file path (outside vault; default: none)
LOG_FILE=sentinel.log
