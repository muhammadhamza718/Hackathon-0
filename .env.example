# Sentinel Watcher Configuration
# Copy this to .env and update values

# Directory to monitor for new files
WATCH_DIRECTORY=/path/to/watch

# Obsidian Vault Inbox path
VAULT_INBOX_PATH=/path/to/vault/Inbox

# Seconds a file must be stable before processing (default: 2.0)
STABILITY_SECONDS=2.0

# Comma-separated allowed file extensions
ALLOWED_EXTENSIONS=.md,.txt,.pdf,.jpg,.jpeg,.png

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: log file path (outside vault)
# LOG_FILE=/path/to/sentinel.log

# === Gold Tier: Odoo 19+ JSON-RPC ===
ODOO_URL=http://localhost:8069
ODOO_DB=my_company
ODOO_USERNAME=admin
ODOO_API_KEY=your-odoo-api-key-here

# === Gold Tier: CEO Briefing ===
CEO_BRIEFING_DAY=6
CEO_BRIEFING_HOUR=22
REVENUE_MONTHLY_GOAL=10000

# === Gold Tier: HITL Thresholds ===
PAYMENT_APPROVAL_THRESHOLD=100.00

# === Gold Tier: Browser MCP ===
BROWSER_MCP_HOST=localhost
BROWSER_MCP_PORT=3000
